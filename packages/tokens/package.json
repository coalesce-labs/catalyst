{
  "name": "@catalyst/tokens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css",
    "./tailwind": "./dist/tailwind.tokens.js",
    "./tokens.json": "./tokens/base.json"
  },
  "files": [
    "dist",
    "tokens",
    "README.md"
  ],
  "scripts": {
    "build": "node build/build.mjs && tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun run build && vitest run",
    "dev": "node build/build.mjs && tsc --watch"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "style-dictionary": "^5.4.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
