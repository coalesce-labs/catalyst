{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "orch-monitor",
  "version": "0.1.0",
  "identifier": "com.catalyst.orch-monitor",
  "build": {
    "beforeDevCommand": "bun run src/write-window-url.ts",
    "beforeBuildCommand": "bun run src/write-window-url.ts",
    "devUrl": "http://mini.rozich.com:7400/",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "orch-monitor",
        "width": 1400,
        "height": 900,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
