#!/usr/bin/env bash
# catalyst-hud — Ink TUI for the catalyst event stream.
# For SSH-from-iPad / minimal-deps fallback, use: catalyst-hud-classic
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
HUD_DIR="${SCRIPT_DIR}/orch-monitor"

# Auto-install deps on first run after a plugin upgrade
if [[ ! -d "${HUD_DIR}/node_modules" ]]; then
  echo "catalyst-hud: installing dependencies (first run after upgrade)…" >&2
  bun install --cwd "${HUD_DIR}" >&2
fi

exec bun run "${HUD_DIR}/cli/hud.tsx" "$@"
