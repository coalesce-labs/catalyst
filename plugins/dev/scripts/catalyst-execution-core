#!/usr/bin/env bash
# catalyst-execution-core — manage the execution-core composing daemon (CTL-554)
#
# The daemon (execution-core/daemon.mjs) composes the CTL-535 Todo-state
# monitor, the CTL-536 pull-loop scheduler, and the CTL-539 recovery contract
# into one long-lived machine-level process, and directory-watches the
# enrollment records that /orchestrate writes in execution-core dispatchMode.
#
# `start`/`stop` here manage the daemon PROCESS — distinct from
# `/orchestrate --stop`, which only deregisters a single project. Modeled on
# catalyst-broker (nohup + PID file, zero-infra portability).
#
# Commands:
#   start      Start the daemon in background (idempotent)
#   stop       Stop the daemon
#   restart    Stop then start
#   probe      Exit 0 if the daemon is running, non-zero otherwise (silent)
#   status     Print running/stopped + pid

set -uo pipefail

CATALYST_DIR="${CATALYST_DIR:-$HOME/catalyst}"
EC_DIR="$CATALYST_DIR/execution-core"
PID_FILE="${EXECUTION_CORE_PID_FILE:-$EC_DIR/daemon.pid}"
LOG_FILE="${EXECUTION_CORE_LOG_FILE:-$EC_DIR/daemon.log}"

# Resolve this script's directory through symlinks (catalyst-broker:39-42).
_SRC="${BASH_SOURCE[0]}"
while [[ -L $_SRC ]]; do _SRC="$(readlink "$_SRC")"; done
SCRIPT_DIR="$(cd "$(dirname "$_SRC")" && pwd)"
unset _SRC

DAEMON_SCRIPT="${EXECUTION_CORE_DAEMON_SCRIPT:-$SCRIPT_DIR/execution-core/daemon.mjs}"
RUNTIME="${EXECUTION_CORE_RUNTIME-}" # empty → resolve_runtime picks bun/node

is_alive() { kill -0 "$1" 2>/dev/null; }

read_pid() {
	if [[ -f $PID_FILE ]]; then
		local pid
		pid="$(cat "$PID_FILE" 2>/dev/null)"
		if [[ $pid =~ ^[0-9]+$ ]] && is_alive "$pid"; then
			echo "$pid"
			return 0
		fi
		rm -f "$PID_FILE" 2>/dev/null
	fi
	return 1
}

resolve_runtime() {
	if [[ -n $RUNTIME ]]; then
		echo "$RUNTIME"
		return 0
	fi
	if command -v bun &>/dev/null; then
		echo "bun"
		return 0
	fi
	if command -v node &>/dev/null; then
		echo "node"
		return 0
	fi
	echo "error: neither bun nor node found on PATH" >&2
	return 1
}

# CTL-635: the daemon's --bg-spare pool freezes OTEL_RESOURCE_ATTRIBUTES at warm
# time and it is immutable thereafter, so every phase worker's
# claude_code_cost_usage_USD_total inherits whatever per-ticket context the
# launch shell composed. Strip the per-ticket keys and stamp a neutral, honest
# daemon identity so bg cost lands in one truthful bucket instead of a borrowed
# ticket. (Per-ticket attribution requires Option D — Anthropic per-job env API.)
_neutralize_otel_attrs() {
	local raw="${1-}" out="" pair key
	local IFS=','
	for pair in $raw; do
		[[ -z $pair ]] && continue
		key="${pair%%=*}"
		case "$key" in
		project | branch | linear.key | catalyst.orchestration | task.type) continue ;;
		*) out="${out:+$out,}$pair" ;;
		esac
	done
	out="${out:+$out,}project=catalyst,catalyst.role=execution-core-daemon"
	printf '%s' "$out"
}

cmd_start() {
	if read_pid >/dev/null 2>&1; then
		echo "catalyst-execution-core already running (pid $(read_pid))"
		return 0
	fi
	local runtime
	runtime=$(resolve_runtime) || return 1
	if [[ ! -f $DAEMON_SCRIPT ]]; then
		echo "error: daemon script not found: $DAEMON_SCRIPT" >&2
		return 1
	fi
	mkdir -p "$EC_DIR" 2>/dev/null || true
	# CTL-635: scrub inherited per-ticket OTEL attrs so the spare pool freezes a
	# neutral daemon bucket, not a borrowed ticket. (Assign then export separately
	# to avoid masking the helper's return value — SC2155.)
	local neutral_otel
	neutral_otel="$(_neutralize_otel_attrs "${OTEL_RESOURCE_ATTRIBUTES-}")"
	export OTEL_RESOURCE_ATTRIBUTES="$neutral_otel"
	nohup "$runtime" "$DAEMON_SCRIPT" --pid-file "$PID_FILE" >"$LOG_FILE" 2>&1 &
	local server_pid=$!
	disown "$server_pid" 2>/dev/null || true
	local waited=0
	while [[ $waited -lt 20 ]]; do
		if [[ -f $PID_FILE ]]; then
			echo "catalyst-execution-core started (pid $(cat "$PID_FILE"))"
			return 0
		fi
		sleep 0.1
		waited=$((waited + 1))
	done
	# CTL-586: the daemon writes its PID file early — immediately after
	# ensureState, before recover/monitor/scheduler boot (daemon.mjs). PID
	# presence means "process up", not "fully reconciled" — the
	# "execution-core daemon started" log line remains the fully-booted
	# signal. A missing PID file after 2s with the process still alive means
	# the daemon wedged before its very-first synchronous write completed —
	# a hard failure, not a transient slow-boot. Fabricating a PID file here
	# would mask a daemon that never wrote one, so report and fail. The
	# daemon stays the sole PID-file writer.
	if is_alive "$server_pid"; then
		echo "error: catalyst-execution-core process $server_pid is alive but has" \
			"not written its PID file after 2s — daemon wedged before initial" \
			"write; check $LOG_FILE" >&2
		return 1
	fi
	echo "error: catalyst-execution-core failed to start — check $LOG_FILE" >&2
	return 1
}

cmd_stop() {
	local pid
	if ! pid=$(read_pid); then
		echo "catalyst-execution-core not running"
		return 0
	fi
	kill "$pid" 2>/dev/null || true
	local waited=0
	while [[ $waited -lt 30 ]] && is_alive "$pid"; do
		sleep 0.1
		waited=$((waited + 1))
	done
	is_alive "$pid" && kill -9 "$pid" 2>/dev/null || true
	rm -f "$PID_FILE" 2>/dev/null
	echo "catalyst-execution-core stopped"
}

cmd_restart() {
	# CTL-635: restart re-applies OTEL env hygiene for free — the scrub lives in
	# cmd_start, which re-warms a fresh daemon (and its spare pool) on restart.
	cmd_stop
	cmd_start
}

cmd_probe() {
	read_pid >/dev/null 2>&1
}

cmd_status() {
	local pid
	if pid=$(read_pid); then
		echo "running (pid $pid)"
		return 0
	fi
	echo "stopped"
}

# CTL-649 Phase 5: route a noun (sessions|worktrees|branches|tidy) to its mjs
# module under execution-core/cli/. The audit CLI lives inside this same binary
# — no new wrapper symlink, no new plist. resolve_runtime picks bun/node.
exec_runtime_module() {
	local module="$1"
	shift
	local module_path="$SCRIPT_DIR/execution-core/cli/${module}.mjs"
	if [[ ! -f $module_path ]]; then
		echo "error: execution-core module not found: $module_path" >&2
		return 1
	fi
	local runtime
	runtime="$(resolve_runtime)" || return 1
	exec "$runtime" "$module_path" "$@"
}

# CTL-649 Phase 5: the daemon-lifecycle verbs, dispatched from both the
# `daemon` noun and the backcompat top-level aliases.
dispatch_daemon() {
	case "${1-}" in
	start) cmd_start ;;
	stop) cmd_stop ;;
	restart) cmd_restart ;;
	probe) cmd_probe ;;
	status) cmd_status ;;
	*)
		echo "Usage: catalyst-execution-core daemon {start|stop|restart|probe|status}" >&2
		exit 1
		;;
	esac
}

# Source-safety (CTL-635): when sourced (e.g. by the test suite to unit-test
# helpers), define functions but do not dispatch a command. `(return 0 2>/dev/null)`
# succeeds only when this file is sourced; the negation guards execution to the
# direct-invocation case.
if ! (return 0 2>/dev/null); then
	case "${1-}" in
	# Backcompat aliases — operator muscle memory for the daemon verbs.
	start | stop | restart | probe | status) dispatch_daemon "$1" ;;
	daemon)
		shift
		dispatch_daemon "${1-}"
		;;
	# CTL-649 audit CLI nouns — each routes to execution-core/cli/<noun>.mjs.
	sessions | worktrees | branches | tidy)
		module="$1"
		shift
		exec_runtime_module "$module" "$@"
		;;
	*)
		echo "Usage: catalyst-execution-core {daemon|sessions|worktrees|branches|tidy} ..." >&2
		echo "  daemon {start|stop|restart|probe|status}  (also as top-level aliases)" >&2
		exit 1
		;;
	esac
fi
