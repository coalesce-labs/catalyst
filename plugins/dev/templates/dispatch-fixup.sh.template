#!/usr/bin/env bash
# dispatch-fixup-${TICKET_ID}.sh — Background dispatch for fix-up worker.
#
# Generated by orchestrate-fixup. Fires a `/catalyst-dev:oneshot`-style fix-up session against an
# already-open PR. The worker reads ${PROMPT_FILE}, resolves the listed blockers, pushes a commit
# to the existing PR branch, and exits. The orchestrator (not this script) confirms the merge
# afterward via its Phase 4 poll loop.
#
# Usage: bash dispatch-fixup-${TICKET_ID}.sh

set -euo pipefail

TICKET_ID="${TICKET_ID}"
ORCH_NAME="${ORCH_NAME}"
ORCH_DIR="${ORCH_DIR}"
WORKER_DIR="${WORKER_DIR}"
PROMPT_FILE="${PROMPT_FILE}"
WORKER_MODEL="${WORKER_MODEL}"
LOG_FILE="${ORCH_DIR}/workers/fixup-${TICKET_ID}-launch.log"
STREAM_FILE="${ORCH_DIR}/workers/fixup-${TICKET_ID}-stream.jsonl"

if [ ! -f "${PROMPT_FILE}" ]; then
  echo "ERROR: prompt file missing: ${PROMPT_FILE}" >&2
  exit 1
fi
if [ ! -d "${WORKER_DIR}" ]; then
  echo "ERROR: worker worktree missing: ${WORKER_DIR}" >&2
  exit 1
fi

PROMPT_BODY="$(cat "${PROMPT_FILE}")"

CATALYST_ORCHESTRATOR_DIR="${ORCH_DIR}" \
CATALYST_ORCHESTRATOR_ID="${ORCH_NAME}" \
claude \
  -n "fixup-${TICKET_ID}" \
  -w "${WORKER_DIR}" \
  --output-format stream-json \
  --verbose \
  -p "${PROMPT_BODY}" \
  > "${STREAM_FILE}" 2> "${LOG_FILE}" &
echo "Dispatched fix-up worker via claude CLI (pid $!)"
